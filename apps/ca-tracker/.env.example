# 可选：配了才会启用 LLM 辅助标签建议，不配也能正常用
ANTHROPIC_API_KEY=

# 可选：自定义 LLM 端点（兼容 Anthropic 的网关）。留空走官方
ANTHROPIC_BASE_URL=

# LLM 模型
LLM_MODEL=claude-haiku-4-5-20251001

# 后台自动抓 DexScreener 快照的间隔（秒）。默认 3600 = 每小时
SNAPSHOT_INTERVAL_SECONDS=3600

# Optional: generate Grok analysis when importing a CA token
GROK_API_KEY=
GROK_BASE_URL=https://api.x.ai/v1
GROK_MODEL=grok-4
